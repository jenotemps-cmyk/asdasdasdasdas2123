local function updatetargetline()
    if not cfg['target line']['enabled'] or not targetlineenabled then
        targetline.Visible = false
        return
    end

    -- Only show tracer when silent aim is actually active (tied to C press / auto mode)
    if not silentaimactive then
        targetline.Visible = false
        return
    end

    if not currenttarget or not currenttarget.Parent then
        targetline.Visible = false
        return
    end

    -- Use UpperTorso if R15, fallback to HumanoidRootPart / Torso
    local torsoPart = currenttarget.Parent:FindFirstChild("UpperTorso") 
                   or currenttarget.Parent:FindFirstChild("Torso") 
                   or currenttarget.Parent:FindFirstChild("HumanoidRootPart")

    if not torsoPart then
        targetline.Visible = false
        return
    end

    local screenpos, onscreen = camera:WorldToViewportPoint(torsoPart.Position)
    if onscreen and screenpos.Z > 0 then
        local mpos = uis:GetMouseLocation()
        targetline.From = Vector2.new(mpos.X, mpos.Y)           -- from crosshair/mouse
        targetline.To = Vector2.new(screenpos.X, screenpos.Y)   -- to torso screen pos
        targetline.Thickness = cfg['target line']['thickness']
        targetline.Transparency = cfg['target line']['transparency']

        -- Color logic (like your pink example when visible)
        if cansee(torsoPart) then
            targetline.Color = cfg['target line']['vulnerable']     -- pink/red when can hit
        else
            targetline.Color = cfg['target line']['invulnerable']   -- gray when wallbang/blocked
        end

        targetline.Visible = true
    else
        targetline.Visible = false
    end
end
