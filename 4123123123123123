-- // Fixed & cleaned version - March 2026 style
-- Removed: skins, headless, rapidfire, superjump, spiderman, hitbox expander, spread hook, target line

getgenv().wizprivate = getgenv().wizprivate or {}

local cfg = getgenv().wizprivate

-- Minimal safety fallbacks
local defaults = {
    ["Checks"] = {
        ["Visible Check"]    = true,
        ["Knock Check"]      = true,
        ["Crew Check"]       = false,   -- not implemented yet
        ["Self Knock Check"] = true,
        ["Forcefield Check"] = true,
    },
    ["Silent Aimbot"] = {
        Enabled = true,
        HitPart = "Head",
        Prediction = {X = 0.165, Y = 0.122, Z = 0},
    },
    ["Camera Aimbot"] = {
        Enabled = false,
        HitPart = "Head",
        Prediction = {X = 0, Y = 0, Z = 0},
        Smoothing = {Enabled = true, X = 0.587, Y = 0.539},
    },
    ["Trigger Bot"] = {
        Enabled = true,
        Delay = 0,
    }
}

for section, tbl in pairs(defaults) do
    if not cfg[section] then
        cfg[section] = tbl
    else
        for k, v in pairs(tbl) do
            if cfg[section][k] == nil then
                cfg[section][k] = v
            end
        end
    end
end

-- Services
local Players           = game:GetService("Players")
local UserInputService  = game:GetService("UserInputService")
local RunService        = game:GetService("RunService")
local Workspace         = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local Camera      = Workspace.CurrentCamera
local Mouse       = LocalPlayer:GetMouse()

-- State
local currentTarget   = nil
local silentActive    = false
local camlockActive   = false
local triggerActive   = false

local rayParams = RaycastParams.new()
rayParams.FilterType = Enum.RaycastFilterType.Exclude
rayParams.IgnoreWater = true

-- FOV visualization parts (simple 3D boxes for now)
local fovParts = {
    silent = Instance.new("Part"),
    camera = Instance.new("Part"),
    trigger = Instance.new("Part"),
}

for _, part in pairs(fovParts) do
    part.Anchored     = true
    part.CanCollide   = false
    part.Transparency = 1
    part.Size         = Vector3.new(1,1,1)
    part.Parent       = Workspace
end

-- Helpers
local function isKnocked(player)
    if not cfg.Checks["Knock Check"] then return false end
    local char = player.Character
    if not char then return false end
    local body = char:FindFirstChild("BodyEffects")
    if not body then return false end
    local ko = body:FindFirstChild("K.O") or body:FindFirstChild("Knocked")
    return ko and ko.Value == true
end

local function selfKnocked()
    if not cfg.Checks["Self Knock Check"] then return false end
    return isKnocked(LocalPlayer)
end

local function isVisible(part)
    if not cfg.Checks["Visible Check"] then return true end
    if not part or not part.Parent then return false end

    local origin = Camera.CFrame.Position
    local direction = (part.Position - origin)
    rayParams.FilterDescendantsInstances = {LocalPlayer.Character or {}, part.Parent}

    local result = Workspace:Raycast(origin, direction, rayParams)
    return not result or result.Instance:IsDescendantOf(part.Parent)
end

local function getClosestTarget()
    local best, bestDist = nil, math.huge
    local mousePos = UserInputService:GetMouseLocation()

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        if not char then continue end

        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        if isKnocked(player) then continue end
        if not isVisible(root) then continue end

        local screen, onScreen = Camera:WorldToViewportPoint(root.Position)
        if not onScreen then continue end

        local dist = (Vector2.new(screen.X, screen.Y) - mousePos).Magnitude
        if dist < bestDist then
            bestDist = dist
            best = root
        end
    end

    if best then
        local desiredPart = best.Parent:FindFirstChild(cfg["Silent Aimbot"].HitPart or "Head")
        return desiredPart or best
    end

    return nil
end

local function predictPosition(part, predTable)
    if not part then return Vector3.zero end
    local vel = part.AssemblyLinearVelocity
    return part.Position + Vector3.new(
        vel.X * (predTable.X or 0.135),
        vel.Y * (predTable.Y or 0.1),
        vel.Z * (predTable.Z or 0)
    )
end

-- Silent Aim hook
local mt = getrawmetatable(game)
local oldIndex = mt.__index
setreadonly(mt, false)

mt.__index = newcclosure(function(self, key)
    if not checkcaller() and self == Mouse and key == "Hit" then
        if cfg["Silent Aimbot"].Enabled and silentActive and currentTarget then
            if not isVisible(currentTarget) then return oldIndex(self, key) end
            local pred = predictPosition(currentTarget, cfg["Silent Aimbot"].Prediction)
            return CFrame.new(Camera.CFrame.Position, pred)
        end
    end
    return oldIndex(self, key)
end)

setreadonly(mt, true)

-- Camera Aimbot
local function updateCameraAimbot()
    if not cfg["Camera Aimbot"].Enabled or not camlockActive then return end
    if selfKnocked() then
        camlockActive = false
        currentTarget = nil
        return
    end

    local targetPart = currentTarget
    if not targetPart or not targetPart.Parent then
        currentTarget = getClosestTarget()
        targetPart = currentTarget
    end

    if not targetPart then return end
    if not isVisible(targetPart) then return end

    local predPos = predictPosition(targetPart, cfg["Camera Aimbot"].Prediction or {})

    local targetCFrame = CFrame.new(Camera.CFrame.Position, predPos)

    if cfg["Camera Aimbot"].Smoothing.Enabled then
        local sx = cfg["Camera Aimbot"].Smoothing.X or 0.6
        local sy = cfg["Camera Aimbot"].Smoothing.Y or 0.6
        Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, 1 - math.min(sx, sy))
    else
        Camera.CFrame = targetCFrame
    end
end

-- Triggerbot
local lastTrigger = 0
local function tryTrigger()
    if not cfg["Trigger Bot"].Enabled or not triggerActive then return end
    if tick() - lastTrigger < (cfg["Trigger Bot"].Delay or 0) then return end
    if selfKnocked() then return end

    local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if not tool then return end

    if currentTarget and isVisible(currentTarget) then
        tool:Activate()
        lastTrigger = tick()
    end
end

-- FOV visualization (very basic)
local function updateFOVBoxes()
    for name, part in pairs(fovParts) do
        part.Transparency = 1
    end

    if silentActive and currentTarget then
        local root = currentTarget.Parent:FindFirstChild("HumanoidRootPart")
        if root then
            fovParts.silent.Size = Vector3.new(12,12,12)
            fovParts.silent.CFrame = root.CFrame
            fovParts.silent.Transparency = 0.92
            fovParts.silent.BrickColor = BrickColor.new("Bright red")
        end
    end

    -- you can add camera & trigger visualization similarly
end

-- Input
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    local key = input.KeyCode.Name

    if key == cfg.Binds.Select or key == cfg.Binds["Camera Aimbot"] then
        if cfg["Targeting"]["Target Mode"] == "Select" then
            silentActive = not silentActive
            if silentActive then
                currentTarget = getClosestTarget()
            else
                currentTarget = nil
            end
        end
    end

    if key == cfg.Binds["Camera Aimbot"] then
        camlockActive = not camlockActive
        if camlockActive then
            currentTarget = getClosestTarget()
        else
            currentTarget = nil
        end
    end

    if key == cfg.Binds.Triggerbot then
        triggerActive = not triggerActive
    end

    if key == cfg.Binds.Speed then
        -- speed toggle (you can re-add if you want)
    end
end)

-- Main loop
RunService.RenderStepped:Connect(function()
    if selfKnocked() then
        silentActive = false
        camlockActive = false
        triggerActive = false
        currentTarget = nil
    end

    if cfg["Targeting"]["Target Mode"] == "Automatic" then
        currentTarget = getClosestTarget()
        silentActive = currentTarget ~= nil
    end

    if silentActive or camlockActive then
        if not currentTarget or not currentTarget.Parent then
            currentTarget = getClosestTarget()
        end
    end

    tryTrigger()
    updateCameraAimbot()
    updateFOVBoxes()
end)

print("[wizprivate fixed] Silent / Cam / Trigger active. Config used from getgenv().wizprivate")
