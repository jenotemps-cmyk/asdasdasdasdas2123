-- Helpers
local function applyPrediction(root, px, py, pz)
    if not root then return CFrame.new() end
    local v = root.Velocity
    return CFrame.new(root.Position + Vector3.new(v.X * px, v.Y * py, v.Z * pz))
end

local function getWeaponCategory()
    local tool = localPlayer.Character and localPlayer.Character:FindFirstChildOfClass("Tool")
    if not tool then return "Others" end
    local n = tool.Name:gsub("[%[%]]", "")
    if ShotgunNames[n] then return "Shotguns" end
    if PistolNames[n]  then return "Pistols"  end
    if AutomaticNames[n] then return "Automatics" end
    if RifleNames[n] then return "Rifles" end
    return "Others"
end

local function getTriggerbotDelay()
    local cfg = getgenv().wizprivate['Trigger Bot']['Delay Settings']
    if not cfg['Delay Toggle'] then return 0 end
    local def = cfg.Delay or 0.095
    if not cfg['Weapon Configuration'] or not cfg['Weapon Configuration'].Enabled then return def end
    local cat = getWeaponCategory()
    return cfg['Weapon Configuration'][cat] and cfg['Weapon Configuration'][cat].Delay or def
end

local function getCameraSmoothness(dist)
    local rs = getgenv().wizprivate['Camera Aimbot']['Range Smoothing']
    if not rs.Enabled then
        local s = getgenv().wizprivate['Camera Aimbot'].Smoothing
        return s.X, s.Y
    end
    if dist <= 30 then return rs.Close.X, rs.Close.Y end
    if dist <= 80 then return rs.Medium.X, rs.Medium.Y end
    return rs.Far.X, rs.Far.Y
end

local function getSplitFOV(sec)
    local f = getgenv().wizprivate[sec].FOV
    local s = f.Size or f
    local cfg = {
        xLeft = s["X Right"] or 12, xRight = s["X Left"] or 12,
        yUpper = s["Y Upper"] or 12, yLower = s["Y Lower"] or 12,
        zLeft = s["Z Right"] or 12, zRight = s["Z Left"] or 12
    }
    local wc = f["Weapon Configuration"]
    if wc and wc.Enabled then
        local cat = getWeaponCategory()
        local w = wc[cat] or wc.Others
        cfg.xLeft  = w["X Right"] or cfg.xLeft
        cfg.xRight = w["X Left"]  or cfg.xRight
        cfg.yUpper = w["Y Upper"] or cfg.yUpper
        cfg.yLower = w["Y Lower"] or cfg.yLower
        cfg.zLeft  = w["Z Right"] or cfg.zLeft
        cfg.zRight = w["Z Left"]  or cfg.zRight
    end
    return cfg
end

