local function isMouseInBoxFOV(box)
    if not box or not box.Parent then return false end
    local mp = UserInputService:GetMouseLocation()
    local ray = camera:ViewportPointToRay(mp.X, mp.Y)
    local lo = box.CFrame:PointToObjectSpace(ray.Origin)
    local ld = box.CFrame:VectorToObjectSpace(ray.Direction).Unit
    local hs = box.Size / 2

    local function axis(o, d, mi, ma)
        if math.abs(d) < 1e-6 then return -math.huge, math.huge end
        local t1, t2 = (mi - o)/d, (ma - o)/d
        return math.min(t1,t2), math.max(t1,t2)
    end

    local tx1,tx2 = axis(lo.X, ld.X, -hs.X, hs.X)
    local ty1,ty2 = axis(lo.Y, ld.Y, -hs.Y, hs.Y)
    local tz1,tz2 = axis(lo.Z, ld.Z, -hs.Z, hs.Z)

    local tmi = math.max(tx1, ty1, tz1)
    local tma = math.min(tx2, ty2, tz2)
    return tma >= math.max(tmi, 0)
end

local function isMouseInSilentFOV()
    if not getgenv().wizprivate['Silent Aimbot'].FOV['Show FOV'] then return true end
    return targetCache.Hitbox and isMouseInBoxFOV(targetCache.Hitbox)
end

local function isMouseInTriggerFOV()
    if not getgenv().wizprivate['Trigger Bot'].FOV['Show FOV'] then return true end
    return targetCache.Trigger and isMouseInBoxFOV(targetCache.Trigger)
end

local function isVisible(origin, part, char)
    if not getgenv().wizprivate.Checks['Visible Check'] then return true end
    if not part or not part:IsA("BasePart") then return false end
    local dir = part.Position - origin
    local p = RaycastParams.new()
    p.FilterType = Enum.RaycastFilterType.Blacklist
    p.FilterDescendantsInstances = {localPlayer.Character, char}
    p.IgnoreWater = true
    local r = Workspace:Raycast(origin, dir, p)
    return not r or r.Instance:IsDescendantOf(char)
end

