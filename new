local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, key)
    if self == mouse and getgenv().wizprivate['Silent Aimbot'].Enabled and targetPlayer and targetPlayer.Character then
        local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not root then return oldIndex(self, key) end

        local cfg = getgenv().wizprivate['Silent Aimbot']
        local isSelect = getgenv().wizprivate['Targeting']['Target Mode'] == "Select"
        local forceHead = isSelect and getgenv().wizprivate['Select Only Features']['Force Hit']

        if not (forceHead or isMouseInSilentFOV()) then
            return oldIndex(self, key)
        end

        local aimPart = forceHead and targetPlayer.Character:FindFirstChild("Head") or root
        if cfg.HitPart ~= "Closest Point" and not forceHead then
            aimPart = targetPlayer.Character:FindFirstChild(cfg.HitPart) or aimPart
        end
        if not aimPart then return oldIndex(self, key) end

        -- prediction
        local p = cfg.Prediction
        local predPos = root.Position + root.Velocity * Vector3.new(p.X, p.Y, p.Z)

        -- raycast camera → predicted position
        local rayFrom = camera.CFrame.Position
        local rayDir = (predPos - rayFrom).Unit * 6000

        local rp = RaycastParams.new()
        rp.FilterType = Enum.RaycastFilterType.Blacklist
        rp.FilterDescendantsInstances = {localPlayer.Character or game}
        rp.IgnoreWater = true

        local res = workspace:Raycast(rayFrom, rayDir, rp)

        local hitPos = predPos
        local hitPart = aimPart

        if res and res.Instance and res.Instance:IsDescendantOf(targetPlayer.Character) then
            hitPos = res.Position
            hitPart = res.Instance
        end

        -- final checks
        if not isVisible(rayFrom, hitPart, targetPlayer.Character) then
            return oldIndex(self, key)
        end

        local ac = cfg["Anti Curve"]
        if ac.Enabled then
            local camLook = camera.CFrame.LookVector
            local toHit = (hitPos - rayFrom).Unit
            local ang = math.deg(math.acos(math.clamp(camLook:Dot(toHit), -1, 1)))

            local maxAng = ac.Angle or 0.5
            if ac['Weapon Configuration'].Enabled then
                local cat = getWeaponCategory()
                local w = ac['Weapon Configuration'][cat] or ac['Weapon Configuration'].Others
                maxAng = w.Angle or maxAng
            end

            if ang > maxAng then
                return oldIndex(self, key)
            end
        end

        if key == "Hit" then
            return CFrame.new(hitPos)
        elseif key == "Target" then
            return hitPart
        end
    end

    return oldIndex(self, key)
end)

