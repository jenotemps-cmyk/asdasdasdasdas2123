task.spawn(function()
    local CommunityID = 17215700
    local function checkMod(plr)
        if getgenv().wizprivate.Global["Mod Detector"] and plr ~= localPlayer and plr:IsInGroup(CommunityID) then
            localPlayer:Kick("A moderator has joined the game!")
            return true
        end
        return false
